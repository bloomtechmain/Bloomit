# Railway Production Environment Variables
# Copy these to your Railway backend service configuration

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://<Railway Database URL>

# Server Configuration
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://erpbloom.com

# JWT Configuration (Generate secure random secrets)
JWT_SECRET=generate-a-strong-random-secret-here
JWT_REFRESH_SECRET=generate-another-strong-random-secret-here

# 📧 EMAIL CONFIGURATION (CRITICAL FOR FUNCTIONALITY)
# Zoho SMTP Configuration
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@bloomaudit.com
SMTP_PASS=your-zoho-smtp-password-here
SMTP_FROM=Bloomtech ERP <info@bloomaudit.com>

# Optional Configuration
TZ=America/Chicago

# Notes:
# - All these variables must be set in Railway's environment variable section
# - JWT secrets should be long random strings (use: openssl rand -base64 32)
# - SMTP credentials are validated and active
# - Email service will gracefully degrade if SMTP not configured
# - Cron jobs use TZ for scheduling (quote reminders run daily at 8 AM)
