{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "ts-node src/scripts/seedAdmin.ts",
    "seed:railway-admin": "ts-node src/scripts/seedRailwayAdmin.ts",
    "reset:admin-password": "ts-node src/scripts/resetAdminPassword.ts",
    "railway:init-db": "ts-node src/scripts/initRailwayDatabase.ts",
    "railway:setup": "npm run railway:init-db && npm run seed:railway-admin",
    "db:ensure:debit-card": "ts-node src/scripts/createDebitCardTable.ts",
    "migrate:contract-id": "ts-node src/scripts/addContractIdToReceivablesPayables.ts",
    "migrate:account-status": "ts-node src/scripts/addEmployeeAccountStatusManagement.ts",
    "migrate:fix-employee-schema": "ts-node src/scripts/fixEmployeeOnboardingSchema.ts",
    "migrate:final-employee-fix": "ts-node src/scripts/finalEmployeeOnboardingFix.ts",
    "fix:employee-sequence": "ts-node src/scripts/fixEmployeeSequence.ts",
    "check:employee-schema": "ts-node src/scripts/checkEmployeeSchema.ts",
    "fix:quotes-permissions": "ts-node src/scripts/fixQuotesPermissions.ts",
    "verify:quotes-access": "ts-node src/scripts/verifyQuotesAccess.ts",
    "fix:super-admin": "ts-node src/scripts/fixSuperAdminAccess.ts",
    "diagnose:super-admin": "ts-node src/scripts/diagnoseSuperAdminIssue.ts",
    "test:jwt-generation": "ts-node src/scripts/testJWTGeneration.ts",
    "migrate:granular-permissions": "ts-node src/scripts/runGranularMigration.ts",
    "fix:railway-errors": "ts-node src/scripts/fixRailwayDatabaseErrors.ts",
    "verify:railway-fix": "ts-node src/scripts/verifyRailwayDatabaseFix.ts",
    "init:railway-portal": "ts-node src/scripts/initRailwayEmployeePortal.ts",
    "verify:railway-portal": "ts-node src/scripts/verifyRailwayEmployeePortal.ts",
    "migrate:documents-tenancy": "ts-node src/scripts/addTenantToDocuments.ts",
    "migrate:employees-tenancy": "ts-node src/scripts/addTenantToEmployees.ts",
    "db:setup-multitenancy": "ts-node src/scripts/setup-multitenancy.ts",
    "db:create-tenants-example": "ts-node src/scripts/create-tenants-example.ts",
    "migrate:marketing-columns": "ts-node src/scripts/addMarketingColumns.ts",
    "fresh-start": "ts-node src/scripts/freshStart.ts",
    "setup:bloomtech": "ts-node src/scripts/setupBloomtech.ts",
    "db:create:packages": "ts-node src/scripts/createPackagesTable.ts",
    "db:add:package-to-users": "ts-node src/scripts/addPackageToUsers.ts",
    "db:create:packages:railway": "cross-env NODE_ENV=production ts-node -r dotenv/config src/scripts/createPackagesTable.ts dotenv_config_path=.env.production",
    "db:add:package-to-users:railway": "cross-env NODE_ENV=production ts-node -r dotenv/config src/scripts/addPackageToUsers.ts dotenv_config_path=.env.production"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.15.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
